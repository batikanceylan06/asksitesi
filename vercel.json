<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>askimiz.com — Sevginizi dijital hatıraya dönüştürün</title>
  <link rel="stylesheet" href="/assets/css/base.css"/>
  <link rel="stylesheet" href="/assets/css/app.css"/>
  <link rel="stylesheet" href="/assets/css/landing.css"/>
</head>
<body>
  <header class="header">
    <div class="container">
      <a class="brand" href="/">
        <div class="logo"></div>
        <div class="t"><b>askimiz.com</b><span>çiftlere özel mini site</span></div>
      </a>
      <nav class="nav">
        <a class="btn" href="/templates">Şablonlar</a>
        <a class="btn primary" href="/create">Sayfanı Oluştur</a>
      </nav>
    </div>
  </header>
  <main class="page">
<section class="hero">
  <div class="container">
    <div class="wrap">
      <div>
        <h1 class="title">Sevginizi <span style="color:#fb7185">dijital</span> bir hatıraya dönüştürün.</h1>
        <div class="lead">
          2 dakikada sipariş verin; sayfanız hazır olsun. Örnek:
          <span class="kbd">askimiz.com/batikan.sezin</span>
        </div>

        <div class="row" style="margin-top:16px">
          <a class="btn primary" href="/create">Sayfanı Oluştur</a>
          <a class="btn" href="/templates">Şablonları İncele</a>
        </div>

        <div class="pillrow">
          <div class="pill">✅ Mobil uyumlu</div>
          <div class="pill">⚡ Hızlı yayın</div>
          <div class="pill">🎵 Müzik</div>
          <div class="pill">🔒 Kilit</div>
          <div class="pill">✨ Premium efekt</div>
        </div>
      </div>

      <div class="hero-card2">
        <div class="small muted">Örnek URL</div>
        <div style="font-weight:980;font-size:18px;margin-top:6px">askimiz.com/batikan.sezin</div>
        <div class="preview-grid">
          <div class="preview-thumb"></div><div class="preview-thumb"></div><div class="preview-thumb"></div>
          <div class="preview-thumb"></div><div class="preview-thumb"></div><div class="preview-thumb"></div>
        </div>
        <div style="height:42px;border-radius:18px;background:#1111;margin-top:12px"></div>
      </div>
    </div>
  </div>
</section>

<div class="container">
  <section class="section">
    <h2>Nasıl çalışır?</h2>
    <div class="sub">Paketini seç, içerik gir, paylaş.</div>
    <div class="grid" style="grid-template-columns:repeat(3,1fr);margin-top:14px">
      <div class="callout"><b>1) Paket + Şablon</b><div class="muted" style="margin-top:8px">Starter / Standart / Premium. Premium’da ayrı şablon seti.</div></div>
      <div class="callout"><b>2) Builder</b><div class="muted" style="margin-top:8px">Foto, hikaye, timeline, video, müzik… Hepsi panelden.</div></div>
      <div class="callout"><b>3) Linkini paylaş</b><div class="muted" style="margin-top:8px">askimiz.com/isim.isim — tek tıkla açılır.</div></div>
    </div>
  </section>

  <section class="section">
    <div style="display:flex;justify-content:space-between;align-items:end;gap:12px;flex-wrap:wrap">
      <div>
        <h2>Paketler</h2>
        <div class="sub">Premium pakette <b>tüm özellikler</b> + <b>premium şablon seti</b> vardır.</div>
      </div>
      <a class="btn" href="/create">Hemen oluştur →</a>
    </div>

    <div class="grid packs" style="margin-top:14px">
      <div class="card price-card">
        <div class="p">
          <div style="display:flex;justify-content:space-between;align-items:center">
            <b>Starter</b><span class="kbd">s1</span>
          </div>
          <div class="price">999 TL</div>
          <div class="list">
            <div class="li">• <b>Demo:</b> /demo/s1</div>
            <div class="li">• 3 foto + mini hikaye</div>
            <div class="li">• Basit görünüm</div>
          </div>
          <div class="row" style="margin-top:14px">
            <a class="btn" href="/demo/s1">Demo</a>
            <a class="btn primary" href="/create?plan=starter">Seç</a>
          </div>
        </div>
      </div>

      <div class="card price-card" style="border-color:#111">
        <div class="p">
          <div class="ribbon">En Popüler</div>
          <div style="display:flex;justify-content:space-between;align-items:center">
            <b>Standart</b><span class="kbd">t1/t2/t3</span>
          </div>
          <div class="price">1499 TL</div>
          <div class="list">
            <div class="li">• Renkli standart skin + daha şık şablonlar</div>
            <div class="li">• 10 foto (yükseltilebilir)</div>
            <div class="li">• Video/animasyon opsiyonel</div>
          </div>
          <div class="row" style="margin-top:14px">
            <a class="btn" href="/demo/t1">Demo</a>
            <a class="btn primary" href="/create?plan=standard">Seç</a>
          </div>
        </div>
      </div>

      <div class="card price-card premium">
        <div class="p">
          <div class="ribbon" style="background:linear-gradient(135deg,#d7b66a,#8b5cf6);color:#111">Premium</div>
          <div style="display:flex;justify-content:space-between;align-items:center">
            <b>Premium</b><span class="kbd">p1/p2/p3</span>
          </div>
          <div class="price">1999 TL</div>
          <div class="list">
            <div class="li">• <b>Tüm özellikler dahil</b> (müzik, kilit, video, animasyon)</div>
            <div class="li">• <b>Canlı sayaç:</b> gün/saat/dakika/saniye</div>
            <div class="li">• Premium lightbox (blur + swipe) + deluxe timeline</div>
          </div>
          <div class="row" style="margin-top:14px">
            <a class="btn" href="/demo/p1">Demo</a>
            <a class="btn primary" href="/create?plan=premium">Premium Al</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div style="display:flex;justify-content:space-between;align-items:end;gap:12px;flex-wrap:wrap">
      <div>
        <h2>Şablonları İncele</h2>
        <div class="sub">Premium’da şablon seti tamamen farklıdır.</div>
      </div>
      <a class="btn" href="/templates">Tüm şablonlar →</a>
    </div>

    <div class="grid" style="grid-template-columns:repeat(3,1fr);gap:14px;margin-top:14px">
      <div class="callout">
        <b>Starter — S1</b>
        <div class="muted" style="margin-top:8px">Sade ve hızlı. Demo ile gösterebilirsin.</div>
        <div class="row" style="margin-top:12px"><a class="btn" href="/demo/s1">Demo</a><a class="btn primary" href="/create?plan=starter">Seç</a></div>
      </div>
      <div class="callout">
        <b>Standart — T seti</b>
        <div class="muted" style="margin-top:8px">Renkli standart skin + modern kartlar.</div>
        <div class="row" style="margin-top:12px"><a class="btn" href="/demo/t2">Demo</a><a class="btn primary" href="/create?plan=standard">Seç</a></div>
      </div>
      <div class="callout" style="border-color:#111">
        <b>Premium — P seti</b>
        <div class="muted" style="margin-top:8px">Glass + glow + canlı sayaç + deluxe modüller.</div>
        <div class="row" style="margin-top:12px"><a class="btn" href="/demo/p3">Demo</a><a class="btn primary" href="/create?plan=premium">Premium</a></div>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Sık sorulanlar</h2>
    <div class="sub">Premium ile “aynı sayfa” hissi olmasın diye şablon setleri ayrıdır.</div>
    <div class="grid" style="grid-template-columns:repeat(2,1fr);gap:14px;margin-top:14px">
      <div class="callout"><b>Premium gerçekten farklı mı?</b><div class="muted" style="margin-top:8px">Evet. Premium şablonları p1/p2/p3 ayrı tasarımdır; ayrıca lightbox + canlı sayaç + deluxe timeline içerir.</div></div>
      <div class="callout"><b>Müzik otomatik çalar mı?</b><div class="muted" style="margin-top:8px">Mobil tarayıcılar otomatik çalmayı engelleyebilir; butonla başlatılır.</div></div>
      <div class="callout"><b>Kilit nasıl çalışır?</b><div class="muted" style="margin-top:8px">PIN belirleyince sayfa açılışta PIN ister.</div></div>
      <div class="callout"><b>Video nasıl eklenir?</b><div class="muted" style="margin-top:8px">Builder’da YouTube embed URL girilir.</div></div>
    </div>
  </section>
</div>
</main>
  <footer class="footer">
    <div class="container">
      <div>© 2026 askimiz.com</div>
      <div>💗 Siz de sevginiz için bir sayfa oluşturun — <b>askimiz.com</b></div>
    </div>
  </footer>
  
</body>
</html>